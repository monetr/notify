{
  "name": "@monetr/notify",
  "version": "1.0.4",
  "description": "Notification/toast component for React.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "build": "pnpm type-check && rslib build",
    "build:analyze": "RSDOCTOR=true pnpm build",
    "clean": "rm -rf node_modules dist",
    "dev": "rslib build --watch",
    "dev:demo": "rsbuild dev",
    "docs:dev": "rspress dev",
    "docs:build": "rspress build",
    "docs:preview": "rspress preview",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "test": "rstest run",
    "test:firefox": "rstest run --browser.name firefox",
    "test:webkit": "rstest run --browser.name webkit"
  },
  "keywords": [
    "react",
    "toast",
    "notification",
    "snackbar",
    "alert"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "provenance": true
  },
  "license": "EPL-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/monetr/notify.git"
  },
  "bugs": {
    "url": "https://github.com/monetr/notify/issues"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@rsbuild/core": "2.0.5",
    "@rsbuild/plugin-react": "2.0.0",
    "@rsdoctor/rspack-plugin": "1.5.10",
    "@rslib/core": "0.21.4",
    "@rspress/core": "2.0.10",
    "@rstest/adapter-rslib": "0.2.2",
    "@rstest/browser": "0.9.10",
    "@rstest/browser-react": "0.9.10",
    "@rstest/core": "0.9.10",
    "@types/node": "24.12.3",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "playwright": "1.59.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "react": "^18.0 || ^19.0.0",
    "react-dom": "^18.0 || ^19.0.0"
  },
  "packageManager": "pnpm@10.33.4",
  "pnpm": {
    "ignoredBuiltDependencies": [
      "core-js",
      "core-js-pure"
    ]
  }
}
