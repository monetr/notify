{
  "name": "@monetr/notify",
  "version": "1.0.6",
  "description": "Notification/toast component for React.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "build": "pnpm type-check && rslib build",
    "build:analyze": "RSDOCTOR=true pnpm build",
    "clean": "rm -rf node_modules dist",
    "dev": "rslib build --watch",
    "dev:demo": "rsbuild dev",
    "docs:dev": "rspress dev",
    "docs:build": "rspress build",
    "docs:preview": "rspress preview",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "test": "rstest run",
    "test:firefox": "rstest run --browser.name firefox",
    "test:webkit": "rstest run --browser.name webkit"
  },
  "keywords": [
    "react",
    "toast",
    "notification",
    "snackbar",
    "alert"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "provenance": true
  },
  "license": "EPL-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/monetr/notify.git"
  },
  "bugs": {
    "url": "https://github.com/monetr/notify/issues"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@rsbuild/core": "2.0.15",
    "@rsbuild/plugin-react": "2.0.1",
    "@rsdoctor/rspack-plugin": "1.5.13",
    "@rslib/core": "0.22.1",
    "@rspress/core": "2.0.14",
    "@rstest/adapter-rslib": "0.10.4",
    "@rstest/browser": "0.10.4",
    "@rstest/browser-react": "0.10.4",
    "@rstest/core": "0.10.4",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "playwright": "1.60.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "packageManager": "pnpm@10.34.3",
  "pnpm": {
    "ignoredBuiltDependencies": [
      "core-js",
      "core-js-pure"
    ]
  }
}
